# Flyto2 Blog SEO thresholds.
SEO_PAGE_SCORE_THRESHOLD=82
SEO_AVERAGE_SCORE_THRESHOLD=88
SEO_HOMEPAGE_SCORE_THRESHOLD=88
SEO_MANAGEMENT_MIN_SCORE=85
SEO_KEYWORD_MATRIX_MAX_AGE_DAYS=100

# Set to true only after Search Console exports are available in CI.
SEO_MANAGEMENT_REQUIRE_GSC=false

# SEO surface inputs.
FLYTO2_SEO_SURFACE=blog
FLYTO2_I18N_SEO_MANIFEST=.seo/i18n-seo-manifest.json

# Optional local Google Search Console CSV exports.
FLYTO2_GSC_QUERIES_CSV=.seo/search-console/queries.csv
FLYTO2_GSC_PAGES_CSV=.seo/search-console/pages.csv
FLYTO2_GSC_QUERY_PAGES_CSV=.seo/search-console/query-pages.csv
FLYTO2_GSC_RANK_TARGETS_CSV=.seo/search-console/rank-targets.csv
